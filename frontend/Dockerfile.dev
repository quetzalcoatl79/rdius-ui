FROM node:22-alpine

# Install wget for the warmup script
RUN apk add --no-cache wget

WORKDIR /app

# Install deps separately for layer caching
COPY package.json package-lock.json ./
RUN npm ci --prefer-offline --no-audit --no-fund

# Copy the rest of the source (will be overlaid by volume mount in dev)
COPY . .

# Make warmup script executable
RUN chmod +x /app/warmup.sh 2>/dev/null || true

EXPOSE 3000

# Start dev server, then run warmup in background
CMD sh -c "/app/warmup.sh & npm run dev"
