sql {
    # PostgreSQL driver
    driver = "rlm_sql_postgresql"
    dialect = "postgresql"

    # Connection settings — use environment variables injected by Docker Compose
    # FreeRADIUS uses $ENV{} for environment variable substitution
    server = "$ENV{POSTGRES_HOST}"
    port = "$ENV{POSTGRES_PORT}"
    login = "$ENV{POSTGRES_USER}"
    password = "$ENV{POSTGRES_PASSWORD}"
    radius_db = "$ENV{POSTGRES_DB}"

    # Target the radius schema — FreeRADIUS tables live in radius.* not public.*
    # PostgreSQL search_path is set on every new connection via open_query
    open_query = "SET search_path TO radius, public"

    # Read NAS clients from the nas table at startup
    # NOTE (CP-3): NAS changes require a full restart, NOT just HUP/reload
    read_clients = yes
    client_table = "nas"

    # Default table names used by the query file
    acct_table1 = "radacct"
    acct_table2 = "radacct"
    postauth_table = "radpostauth"
    authcheck_table = "radcheck"
    authreply_table = "radreply"
    groupcheck_table = "radgroupcheck"
    groupreply_table = "radgroupreply"
    usergroup_table = "radusergroup"

    # Group-related settings
    group_attribute = "SQL-Group"

    # Delete stale session entries
    delete_stale_sessions = yes

    # Include the queries
    $INCLUDE ${modconfdir}/${.:name}/main/${dialect}/queries.conf

    # Connection pool settings
    pool {
        # Number of connections to open at startup
        start = 5
        # Minimum open connections to keep alive
        min = 4
        # Maximum simultaneous connections
        max = 10
        # Number of idle connections to maintain
        spare = 3
        # Maximum queries per connection (0 = unlimited)
        uses = 0
        # Maximum connection lifetime in seconds (0 = unlimited)
        lifetime = 0
        # Idle timeout in seconds before connection is closed
        idle_timeout = 60
    }
}
